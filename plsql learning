    DBMS_OUTPUT.PUT_LINE(
        'High Salary Count : ' || v_count
    );
END;
/

Function 更适合计算并返回一个值。
CREATE OR REPLACE FUNCTION get_salary(
    p_employee_id hr.employees.employee_id%TYPE
)
RETURN hr.employees.salary%TYPE
IS
    v_salary hr.employees.salary%TYPE;
BEGIN

    SELECT salary
    INTO v_salary
    FROM hr.employees
    WHERE employee_id = p_employee_id;

    RETURN v_salary;

END;
/

打包
CREATE OR REPLACE PACKAGE BODY salary_pkg
IS

    PROCEDURE count_high_salary(
        p_salary IN hr.employees.salary%TYPE,
        p_count OUT NUMBER
    )
    IS
    BEGIN

        SELECT COUNT(*)
        INTO p_count
        FROM hr.employees
        WHERE salary>=p_salary;

    END;

END salary_pkg;
/


