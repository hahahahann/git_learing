建立存储，可以往里面传参数
CREATE OR REPLACE PROCEDURE count_high_salary(
p_salary in hr.employees.salary%TYPe,
p_count OUT NUMBER)
is
BEGIN
SELECT COUNT(*)
INTO p_count
FROM hr.employees
WHERE salary >= p_salary;
end;
调用存储
DECLARE
    v_count NUMBER;
BEGIN
