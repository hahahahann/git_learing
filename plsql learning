    l_day date := sysdate;
-- sysdate是系统自带的时间，date是日期，在plsql里面=只写在sql里面别的地方是 :=
BEGIN
    DBMS_OUTPUT.put_line('today is '||to_char(l_day,'day')); 
-- 打印结果，to_char 是转换字符串格式，|| 拼接作用和&是一样的 'YYYY-MM-DD' 'DD/MM/YYYY' 'Day'  'D' 
