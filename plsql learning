CREATE OR REPLACE TRIGGER emp_audit_trigger
AFTER INSERT OR UPDATE OR DELETE
ON EMPLOYEES
FOR EACH ROW
BEGIN
  IF INSERTING THEN
    DBMS_OUTPUT.PUT_LINE('执行了 INSERT');
  ELSIF UPDATING THEN
    DBMS_OUTPUT.PUT_LINE('执行了 UPDATE');
  ELSIF DELETING THEN
    DBMS_OUTPUT.PUT_LINE('执行了 DELETE');
  END IF;
END emp_audit_trigger;
/


